# ============================================================================
# Fingent configuration — copy this file to ".env" and fill in what you want.
# Everything here is OPTIONAL. With nothing set, Fingent runs in demo mode.
# Uncomment a line (remove the leading #) and add your value to enable it.
# ============================================================================

# --- Reasoning model (LLM) --------------------------------------------------
# Enables the REAL agent-building + tool-calling loop (mode: "llm").
# Without it, a deterministic demo engine runs instead.
# Get a free Groq key at: https://console.groq.com/keys
#GROQ_API_KEY=gsk_your_key_here

# Google Gemini — auto-detected via its OpenAI-compatible endpoint (native tool-calling,
# streaming and JSON all work, no Google SDK needed). Key: https://aistudio.google.com/apikey
#GEMINI_API_KEY=your_gemini_key_here
#GEMINI_MODEL=gemini-2.5-flash      # default; gemini-2.0-flash also works if it has quota

# Optional: any other OpenAI-compatible provider (OpenAI, Azure, vLLM, Ollama…).
#FINGENT_LLM_API_KEY=sk-your_key_here
#FINGENT_LLM_BASE_URL=https://api.openai.com/v1
#FINGENT_LLM_MODEL=gpt-4o-mini

# Model choice. Default is llama-3.3-70b-versatile. For markedly better reasoning and
# tool use (and cheaper output), use openai/gpt-oss-120b. Other strong options:
# meta-llama/llama-4-maverick-17b-128e-instruct, qwen/qwen3-32b.
#GROQ_MODEL=openai/gpt-oss-120b

# Cap on response length (raise for long structured answers; default 4096).
#FINGENT_LLM_MAX_TOKENS=4096

# --- Authentication & access control ---------------------------------------
# Open dev mode (default): no login, every caller is admin of the default tenant.
# Set these for a real deployment. The app refuses to start under FINGENT_REQUIRE_SECURE=1
# if any of these are insecure (open mode, default admin, or plaintext passwords).
#FINGENT_AUTH=1                       # require login (bearer session token)
#FINGENT_REQUIRE_SECURE=1             # hard-fail on insecure config; reject plaintext logins
#FINGENT_SESSION_TTL_HOURS=8          # session lifetime (default 8h)
#FINGENT_LOGIN_MAX_ATTEMPTS=5         # failed logins before lockout
#FINGENT_LOGIN_LOCKOUT_SECONDS=300    # lockout window
# Users with HASHED passwords (mint a hash: python -m fingent.hashpw <password>):
#FINGENT_USERS={"alice": {"password": "pbkdf2$...", "tenant": "acme", "roles": ["admin"]}}

# --- Credential vault -------------------------------------------------------
# Master key for encrypting tool credentials at rest. If unset, a key is generated and
# stored in the database (fine for local use). For production, set this from a KMS/secret
# manager so the key lives OUTSIDE the database.
#FINGENT_VAULT_KEY=change-me-to-a-long-random-string

# --- Document OCR (vision) --------------------------------------------------
# document_intelligence / ocr_extract read document IMAGES with a Groq vision model using
# your existing GROQ_API_KEY - no separate OCR service needed. Pass the document as an
# image URL, data: URL, or image file. Override the model if you like:
#FINGENT_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
#OCR_API_URL=                         # optional: a custom OCR endpoint, overrides vision

# --- Live data tools --------------------------------------------------------
# Live web search (web_search). Get a key at: https://app.tavily.com
#TAVILY_API_KEY=tvly-your_key_here

# Live sanctions / PEP screening (pep_check) via OpenSanctions.
# https://www.opensanctions.org/api/
#OPENSANCTIONS_API_KEY=your_key_here

# Live decision-maker discovery (find_persona) via People Data Labs.
# https://www.peopledatalabs.com
#PEOPLE_DATA_API_KEY=your_key_here

# Live contact resolution (resolve_contact) via Hunter.io.
# https://hunter.io/api-keys
#HUNTER_API_KEY=your_key_here

# --- Storage ----------------------------------------------------------------
# SQLite path. Defaults to fingent.db (set by run scripts). Use :memory: for ephemeral.
#FINGENT_DB=fingent.db

# --- Optional hardening -----------------------------------------------------
# Require login (users from FINGENT_USERS; default admin/admin -> tenant acme)
#FINGENT_AUTH=1
# Machine-to-machine tokens: {"token":"tenant"}
#FINGENT_TENANT_TOKENS={"secret-token":"acme"}
